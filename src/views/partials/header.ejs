<!DOCTYPE html>
<html lang="en" class="no-js">
  <head>
    <meta charset="UTF-8">

    <meta
      name="viewport"
      content="width=device-width, initial-scale=1"
    >

    <meta
      name="description"
      content="A reusable Node.js and Express starter for client websites."
    >

    <title><%= title %> | Node Client Starter</title>

    <link rel="stylesheet" href="/css/main.css">

    <script type="module" src="/js/main.js" defer></script>
  </head>

  <body>
    <header class="site-header">
      <nav class="navbar" aria-label="Main navigation">
        <a class="navbar__brand" href="#">Brand</a>

        <button
          class="navbar__toggle"
          type="button"
          aria-label="Toggle navigation menu"
          aria-controls="main-menu"
          aria-expanded="false"
        >
          <span class="navbar__icon" aria-hidden="true"></span>
        </button>

        <div class="navbar__menu" id="main-menu" data-open="false">
          <ul class="navbar__list">
            <li>
              <a class="navbar__link" href="#" aria-current="page">Home</a>
            </li>
            <li><a class="navbar__link" href="#">About</a></li>
            <li><a class="navbar__link" href="#">Services</a></li>
            <li><a class="navbar__link" href="#">Portfolio</a></li>
            <li><a class="navbar__link" href="#">Contact</a></li>
          </ul>
        </div>
      </nav>
    </header>